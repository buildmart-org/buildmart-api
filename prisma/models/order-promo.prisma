model OrderPromo {
    id           String   @id @default(uuid()) @db.Uuid
    code         String   @unique
    discount     Decimal  @db.Decimal(5,2)
    isActive     Boolean  @default(true)
    createdAt    DateTime @default(now())

    orders       Order[]

    @@index([code])
    @@map("orders-promos")
}


